#include <WiFi.h>
#include <WebServer.h>
#include <SPI.h>
#include <MFRC522.h>

// ---------------- WIFI ----------------
const char* ssid = "ESP NAME";
const char* password = "12345678";

WebServer server(80);

// ---------------- RFID ----------------
#define SS_PIN 21
#define RST_PIN 22
MFRC522 mfrc522(SS_PIN, RST_PIN);

// ---------------- STATE ----------------
String lastUID = "None";
String lastData = "No scan yet";
String lastStatus = "Idle";

// WRITE STATE (IMPORTANT FIX)
bool writeMode = false;
String pendingWriteData = "";
String selectedUID = "";

// timing
unsigned long lastScanTime = 0;

// ---------------- UID DB ----------------
#define MAX_UIDS 10
String recentUIDs[MAX_UIDS];
int uidIndex = 0;

// ---------------- HELPERS ----------------
String byteArrayToHex(byte *buffer, byte size) {
  String result = "";
  for (byte i = 0; i < size; i++) {
    if (buffer[i] < 0x10) result += "0";
    result += String(buffer[i], HEX);
  }
  return result;
}

void hexStringToBytes(String hex, byte *output, int len) {
  for (int i = 0; i < len; i++) {
    String byteString = hex.substring(i * 2, i * 2 + 2);
    output[i] = (byte) strtol(byteString.c_str(), NULL, 16);
  }
}

// store UID (for UI only)
void storeUID(String uid) {
  for (int i = 0; i < MAX_UIDS; i++) {
    if (recentUIDs[i] == uid) return;
  }

  recentUIDs[uidIndex] = uid;
  uidIndex = (uidIndex + 1) % MAX_UIDS;
}

// ---------------- WEB PAGE ----------------
String webpage() {
  String html = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
  <title>ESP32 RFID System</title>
</head>

<body>
  <h1>ESP32 RFID System</h1>

  <h3>Status:</h3>
  <p id="status">Loading...</p>

  <h3>Last UID:</h3>
  <p id="uid">---</p>

  <h3>Last Data (Block 4):</h3>
  <p id="data">---</p>

  <hr>

  <h2>Manual Write (16 bytes = 32 hex chars)</h2>
  <form action="/write">
    <input name="data" placeholder="32 hex chars" size="40">
    <button type="submit">Write Manual</button>
  </form>

  <hr>

  <h2>Recent Cards (Click to COPY stored data)</h2>
  <div id="uids"></div>

<script>

async function update() {
  const res = await fetch('/data');
  const j = await res.json();

  document.getElementById('status').innerText = j.status;
  document.getElementById('uid').innerText = j.uid;
  document.getElementById('data').innerText = j.data;
}

async function loadUIDs() {
  const res = await fetch('/uids');
  const list = await res.json();

  let html = "";

  for (let i = 0; i < list.length; i++) {
    html += `<p>
      <a href="/select?uid=${list[i]}">
        ${list[i]}
      </a>
    </p>`;
  }

  document.getElementById("uids").innerHTML = html;
}

setInterval(update, 1000);
setInterval(loadUIDs, 2000);

update();
loadUIDs();

</script>

</body>
</html>
)rawliteral";

  return html;
}

// ---------------- JSON ----------------
void handleData() {
  String json = "{";
  json += "\"status\":\"" + lastStatus + "\",";
  json += "\"uid\":\"" + lastUID + "\",";
  json += "\"data\":\"" + lastData + "\"";
  json += "}";

  server.send(200, "application/json", json);
}

// ---------------- UID LIST ----------------
void handleUIDs() {
  String json = "[";
  for (int i = 0; i < MAX_UIDS; i++) {
    if (recentUIDs[i].length() > 0) {
      json += "\"" + recentUIDs[i] + "\",";
    }
  }
  json += "]";
  json.replace(",]", "]");

  server.send(200, "application/json", json);
}

// ---------------- CLICK UID (FIXED) ----------------
// Now correctly copies LAST READ BLOCK DATA (NOT UID)
void handleSelect() {
  if (!server.hasArg("uid")) return;

  selectedUID = server.arg("uid");

  // FIX: we ONLY copy stored DATA, not UID
  pendingWriteData = lastData;

  writeMode = true;

  lastStatus = "READY: will COPY stored RFID BLOCK data";

  server.sendHeader("Location", "/");
  server.send(303);
}

// ---------------- MANUAL WRITE ----------------
void handleWrite() {
  if (!server.hasArg("data")) {
    lastStatus = "No data provided";
    server.sendHeader("Location", "/");
    server.send(303);
    return;
  }

  String data = server.arg("data");

  if (data.length() != 32) {
    lastStatus = "Must be 32 hex chars (16 bytes)";
    server.sendHeader("Location", "/");
    server.send(303);
    return;
  }

  pendingWriteData = data;
  writeMode = true;

  lastStatus = "READY: manual write armed";

  server.sendHeader("Location", "/");
  server.send(303);
}

// ---------------- ROOT ----------------
void handleRoot() {
  server.send(200, "text/html", webpage());
}

// ---------------- RFID LOOP ----------------
void scanRFID() {

  if (!mfrc522.PICC_IsNewCardPresent()) return;
  if (!mfrc522.PICC_ReadCardSerial()) return;

  if (millis() - lastScanTime < 1000) {
    mfrc522.PICC_HaltA();
    return;
  }

  lastScanTime = millis();

  // UID
  lastUID = byteArrayToHex(mfrc522.uid.uidByte, mfrc522.uid.size);
  storeUID(lastUID);

  // READ BLOCK 4
  byte block = 4;
  byte buffer[18];
  byte size = sizeof(buffer);

  MFRC522::MIFARE_Key key;
  for (byte i = 0; i < 6; i++) key.keyByte[i] = 0xFF;

  MFRC522::StatusCode status;

  status = mfrc522.PCD_Authenticate(
    MFRC522::PICC_CMD_MF_AUTH_KEY_A,
    block,
    &key,
    &(mfrc522.uid)
  );

  if (status != MFRC522::STATUS_OK) {
    lastStatus = "AUTH FAILED";
  } 
  else {

    // ---------------- WRITE ----------------
    if (writeMode) {

      byte dataBlock[16];
      hexStringToBytes(pendingWriteData, dataBlock, 16);

      if (mfrc522.MIFARE_Write(block, dataBlock, 16) == MFRC522::STATUS_OK) {
        lastStatus = "WRITE SUCCESS";
        lastData = pendingWriteData;
      } else {
        lastStatus = "WRITE FAILED";
      }

      writeMode = false;
      pendingWriteData = "";
    }

    // ---------------- READ ----------------
    else {
      if (mfrc522.MIFARE_Read(block, buffer, &size) == MFRC522::STATUS_OK) {
        lastData = byteArrayToHex(buffer, 16);
        lastStatus = "READ OK";
      } else {
        lastStatus = "READ FAILED";
      }
    }
  }

  mfrc522.PICC_HaltA();
  mfrc522.PCD_StopCrypto1();
}

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(115200);

  SPI.begin();
  mfrc522.PCD_Init();

  WiFi.softAP(ssid, password);

  server.on("/", handleRoot);
  server.on("/data", handleData);
  server.on("/uids", handleUIDs);
  server.on("/select", handleSelect);
  server.on("/write", handleWrite);

  server.begin();

  Serial.println(WiFi.softAPIP());
}

// ---------------- LOOP ----------------
void loop() {
  server.handleClient();
  scanRFID();
}
